# -----------------------------------------------
# Copy this file to .env and fill in the values.
# Most values below work as-is for local QA runs.
# Lines marked REPLACE need real credentials.
# -----------------------------------------------

# --- SQL Server ---
SA_PASSWORD=Admin@1234

# Points to the sqlserver container — keep in sync with SA_PASSWORD above
DB_CONNECTION_STRING=Server=vc-sqlserver,1433;Database=VictoryCenterDb;User Id=sa;Password=Admin@1234;MultipleActiveResultSets=true;TrustServerCertificate=true;Encrypt=false;

# --- Admin seed account (created on first run) ---
INITIAL_ADMIN_EMAIL=admintest@gmail.com
INITIAL_ADMIN_PASSWORD=P123w0rd!

# --- JWT (any random 32+ char string works locally) ---
JWTOPTIONS_SECRETKEY=local-jwt-access-token-secret-key-32ch
JWTOPTIONS_REFRESH_TOKEN_SECRETKEY=local-jwt-refresh-token-secret-key-32ch

# --- File storage ---
BLOB_LOCAL_STORE_KEY=my-super-secret-local-key

# --- Way4Pay (payment gateway) ---
# Leave empty locally — payment flows won't work but the rest of the app will
WAY4PAY_MERCHANT_LOGIN=
WAY4PAY_MERCHANT_SECRET_KEY=
WAY4PAY_MERCHANT_DOMAIN_NAME=http://localhost:3000
WAY4PAY_API_URL=https://secure.wayforpay.com/pay

# --- Cloudflare Turnstile (CAPTCHA) ---
# These are Cloudflare's official test keys — always pass, safe to use locally
# https://developers.cloudflare.com/turnstile/reference/testing/
REACT_APP_CF_TURNSTILE_SITE_KEY=1x00000000000000000000AA
CLOUDFLARE_TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
CLOUDFLARE_TURNSTILE_SITE_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify

# --- Email ---
# EmailProvider is set to "Dummy" in Development — emails are logged, not sent
# REPLACE if you need actual email delivery (get token at resend.com)
RESEND_API_TOKEN=
CONTACT_US_EMAIL_OPTIONS_FROM_ADDRESS=noreply@example.com
CONTACT_US_EMAIL_FROM_ADDRESS=noreply@example.com

# --- Frontend backend URL ---
# Default http://localhost:8080/api works if you haven't changed the backend port
# REACT_APP_BACKEND_URL=http://localhost:8080/api
